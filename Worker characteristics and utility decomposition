# =============================================
# 2. AoI-Aware Incentive Calculation
# =============================================

def calculate_aoi_aware_q(B, N, gamma, c, epsilon_i, A_i, lambda_aoi, kappa, p_i):
    effective_cost = (1 - epsilon_i) * np.exp(-lambda_aoi * A_i) + kappa * A_i
    q_unconst = (np.sqrt(2 * B * gamma * c / N + (gamma * c * effective_cost)**2)
                 - gamma * c * effective_cost) / (p_i + effective_cost)
    total = np.sum(q_unconst * (p_i + effective_cost))
    scaling = B / total if total > 0 else 1.0
    q_i = q_unconst * scaling
    return np.maximum(q_i, 0.1)

