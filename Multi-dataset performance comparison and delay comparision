            'MOCHA': [1.6, 1.05, 0.82, 0.65, 0.55, 0.48, 0.42, 0.38, 0.35, 0.32],
            'AoI-MOCHA': [1.35, 0.82, 0.58, 0.45, 0.38, 0.33, 0.28, 0.25, 0.22, 0.20]
        },
        'HAR': {
            'FedAvg': [2.10, 1.35, 1.05, 0.85, 0.72, 0.65, 0.58, 0.52, 0.48, 0.44],
            'MOCHA': [1.75, 1.15, 0.90, 0.72, 0.60, 0.52, 0.46, 0.40, 0.36, 0.32],
            'AoI-MOCHA': [1.45, 0.88, 0.62, 0.48, 0.40, 0.35, 0.30, 0.26, 0.22, 0.20]
        }
    }
    return N_values, delay_data[dataset]['MOCHA'], delay_data[dataset]['AoI-MOCHA'], delay_data[dataset]['FedAvg']

