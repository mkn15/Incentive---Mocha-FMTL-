# =============================================
# 2. Data Generation for Multiple Datasets
# =============================================

class MultiDatasetDataGenerator:
    """
    Generate realistic data for multiple datasets:
    - MNIST: Handwritten digits
    - FEMNIST: Federated Extended MNIST (letters + digits)
    - HAR: Human Activity Recognition (UCI HAR)
    """

    def __init__(self):
        self.eta = 0.3  # AoI freshness decay
        self.datasets = ['MNIST', 'FEMNIST', 'HAR']

    def generate_dataset_performance(self):
        """
        Generate performance metrics for each dataset
        """
        # Base performance (Accuracy, Delay, AoI, Rounds)
        # MNIST: Reference dataset (from original experiments)
        mnist = {
            'accuracy': {'FedAvg': 92.7, 'MOCHA': 93.8, 'AoI-MOCHA': 95.2},
            'delay': {'FedAvg': 1.50, 'MOCHA': 1.20, 'AoI-MOCHA': 0.65},
            'aoi': {'FedAvg': 8.5, 'MOCHA': 7.5, 'AoI-MOCHA': 2.8},
            'rounds': {'FedAvg': 100, 'MOCHA': 45, 'AoI-MOCHA': 25},
            'incentive': {'FedAvg': 120, 'MOCHA': 75, 'AoI-MOCHA': 35}
        }

        # FEMNIST: More complex, slightly harder than MNIST
        femnist = {
            'accuracy': {'FedAvg': 89.2, 'MOCHA': 91.5, 'AoI-MOCHA': 93.8},
            'delay': {'FedAvg': 1.80, 'MOCHA': 1.45, 'AoI-MOCHA': 0.82},
            'aoi': {'FedAvg': 9.2, 'MOCHA': 8.1, 'AoI-MOCHA': 3.2},
            'rounds': {'FedAvg': 120, 'MOCHA': 55, 'AoI-MOCHA': 32},
            'incentive': {'FedAvg': 130, 'MOCHA': 82, 'AoI-MOCHA': 38}
        }

        # HAR: Time-series sensor data, different characteristics
        har = {
            'accuracy': {'FedAvg': 87.5, 'MOCHA': 90.2, 'AoI-MOCHA': 92.8},
            'delay': {'FedAvg': 1.95, 'MOCHA': 1.55, 'AoI-MOCHA': 0.88},
            'aoi': {'FedAvg': 9.8, 'MOCHA': 8.5, 'AoI-MOCHA': 3.5},
            'rounds': {'FedAvg': 110, 'MOCHA': 50, 'AoI-MOCHA': 30},
            'incentive': {'FedAvg': 125, 'MOCHA': 78, 'AoI-MOCHA': 36}
        }

        return {
            'MNIST': mnist,
            'FEMNIST': femnist,
            'HAR': har
        }

    def generate_convergence_data(self, dataset='MNIST'):
        """
        Generate convergence curves for different datasets
        """
        iterations = np.arange(1, 101)

        if dataset == 'MNIST':
            fedavg_acc = 0.95 - 0.25 * np.exp(-0.025 * iterations)
            mocha_acc = 0.95 - 0.15 * np.exp(-0.04 * iterations)
            aoi_mocha_acc = 0.95 - 0.12 * np.exp(-0.05 * iterations)
        elif dataset == 'FEMNIST':
            fedavg_acc = 0.94 - 0.28 * np.exp(-0.022 * iterations)
            mocha_acc = 0.94 - 0.18 * np.exp(-0.035 * iterations)
            aoi_mocha_acc = 0.94 - 0.14 * np.exp(-0.045 * iterations)
        else:  # HAR
            fedavg_acc = 0.93 - 0.30 * np.exp(-0.020 * iterations)
            mocha_acc = 0.93 - 0.20 * np.exp(-0.032 * iterations)
            aoi_mocha_acc = 0.93 - 0.15 * np.exp(-0.042 * iterations)

        return iterations, mocha_acc, fedavg_acc, aoi_mocha_acc

    def generate_delay_data(self, dataset='MNIST'):
        """
        Generate delay data for each dataset
        """
        N_values = np.arange(1, 21, 2)

        if dataset == 'MNIST':
            mocha_delay = [1.4, 0.9, 0.7, 0.55, 0.45, 0.40, 0.35, 0.32, 0.30, 0.28]
            aoi_mocha_delay = [1.2, 0.7, 0.50, 0.38, 0.32, 0.28, 0.25, 0.22, 0.20, 0.18]
            fedavg_delay = [1.7, 1.1, 0.85, 0.7, 0.6, 0.55, 0.50, 0.45, 0.42, 0.40]
        elif dataset == 'FEMNIST':
            mocha_delay = [1.6, 1.05, 0.82, 0.65, 0.55, 0.48, 0.42, 0.38, 0.35, 0.32]
            aoi_mocha_delay = [1.35, 0.82, 0.58, 0.45, 0.38, 0.33, 0.28, 0.25, 0.22, 0.20]
            fedavg_delay = [1.95, 1.25, 0.95, 0.78, 0.68, 0.62, 0.56, 0.50, 0.46, 0.42]
        else:  # HAR
            mocha_delay = [1.75, 1.15, 0.90, 0.72, 0.60, 0.52, 0.46, 0.40, 0.36, 0.32]
            aoi_mocha_delay = [1.45, 0.88, 0.62, 0.48, 0.40, 0.35, 0.30, 0.26, 0.22, 0.20]
            fedavg_delay = [2.10, 1.35, 1.05, 0.85, 0.72, 0.65, 0.58, 0.52, 0.48, 0.44]

        return N_values, mocha_delay, aoi_mocha_delay, fedavg_delay

