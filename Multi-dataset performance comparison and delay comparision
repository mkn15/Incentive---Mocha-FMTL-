# =============================================
# 4. Data Generators
# =============================================

def generate_convergence_data(dataset):
    iterations = np.arange(1, 101)
    if dataset == 'MNIST':
        fedavg = 0.95 - 0.25 * np.exp(-0.025 * iterations)
        mocha = 0.95 - 0.15 * np.exp(-0.04 * iterations)
        aoi_mocha = 0.95 - 0.12 * np.exp(-0.05 * iterations)
    elif dataset == 'FEMNIST':
        fedavg = 0.94 - 0.28 * np.exp(-0.022 * iterations)
        mocha = 0.94 - 0.18 * np.exp(-0.035 * iterations)
        aoi_mocha = 0.94 - 0.14 * np.exp(-0.045 * iterations)
    else:
        fedavg = 0.93 - 0.30 * np.exp(-0.020 * iterations)
        mocha = 0.93 - 0.20 * np.exp(-0.032 * iterations)
        aoi_mocha = 0.93 - 0.15 * np.exp(-0.042 * iterations)
    return iterations, mocha, fedavg, aoi_mocha

