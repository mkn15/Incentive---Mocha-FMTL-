        }

        return N_values, budgets, aoi_mocha_delay

    def generate_utility_data(self):
        """
        Generate follower utility data (Stackelberg game)
        Utility increases with incentive rate q*
        """
        incentive_values = np.linspace(1, 10, 10)
        budgets = [2, 5, 10, 20, 35]

        utility_data = {
            2: [0.8, 1.2, 1.5, 1.8, 2.0, 2.2, 2.3, 2.4, 2.5, 2.6],
            5: [1.0, 1.4, 1.8, 2.2, 2.5, 2.8, 3.0, 3.2, 3.4, 3.6],
