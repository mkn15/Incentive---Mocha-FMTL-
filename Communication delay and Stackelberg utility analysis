            35: [1.8, 2.5, 3.2, 4.0, 4.5, 5.0, 5.3, 5.5, 5.8, 6.0]
        }

        return incentive_values, budgets, utility_data

    def generate_gain_data(self):
        """
        Generate performance gain data (MOCHA vs FedAvg & AoI-MOCHA vs MOCHA)
        """
        budgets = [2, 5, 10, 20, 35]

        # MOCHA performance gains over FedAvg (15-25%)
        mocha_gains = {
            2: [12.5, 14.2, 13.8, 15.0, 14.5, 13.2, 14.8, 15.5, 14.0, 13.5],
            5: [16.8, 18.5, 17.2, 19.0, 18.2, 17.5, 19.5, 18.0, 17.8, 18.8],
            10: [20.5, 22.0, 21.5, 23.2, 22.5, 21.0, 22.8, 23.5, 21.5, 22.2],
            20: [24.5, 26.0, 25.5, 27.0, 26.5, 25.0, 26.8, 27.5, 25.8, 26.2],
            35: [27.0, 28.5, 28.0, 29.5, 28.8, 27.5, 29.0, 30.0, 28.5, 29.2]
        }

        # Average gains
        avg_mocha_gains = [np.mean(mocha_gains[B]) for B in budgets]
        std_mocha_gains = [np.std(mocha_gains[B]) for B in budgets]

        # AoI-MOCHA gains over MOCHA (additional 10-15%)
        aoi_gains = {
            2: [8.5, 9.2, 8.8, 9.5, 9.0, 8.5, 9.2, 9.8, 8.8, 9.0],
            5: [10.5, 11.2, 10.8, 11.5, 11.0, 10.5, 11.2, 11.8, 10.8, 11.0],
            10: [12.5, 13.2, 12.8, 13.5, 13.0, 12.5, 13.2, 13.8, 12.8, 13.0],
            20: [14.0, 14.8, 14.5, 15.2, 14.8, 14.2, 15.0, 15.5, 14.5, 14.8],
            35: [15.0, 15.8, 15.5, 16.2, 15.8, 15.2, 16.0, 16.5, 15.5, 15.8]
        }

        avg_aoi_gains = [np.mean(aoi_gains[B]) for B in budgets]
        std_aoi_gains = [np.std(aoi_gains[B]) for B in budgets]

        return budgets, avg_mocha_gains, std_mocha_gains, avg_aoi_gains, std_aoi_gains

    def generate_aoi_data(self):
        """
        Generate AoI freshness weight data
        β_i(t) = e^{-η * AoI_i(t)} / Σ e^{-η * AoI_k(t)}
        """
        age = np.arange(0, 11)
        eta = 0.3

        # Exponential decay
        raw_weights = np.exp(-eta * age)

        # Normalize
        weights = raw_weights / raw_weights[0]  # Normalize to 1 at age=0

        return age, weights

    def generate_optimal_workers_data(self):
        """
        Generate optimal workers data for MOCHA
        """
        budgets = [2, 5, 10, 20, 35]
        target_errors = [0.10, 0.15, 0.20, 0.25]

        optimal_workers = {
            0.10: [4, 8, 14, 18, 20],
            0.15: [3, 6, 10, 16, 18],
            0.20: [2, 4, 8, 12, 15],
            0.25: [1, 3, 6, 8, 10]
        }

        return budgets, target_errors, optimal_workers

    def generate_convergence_data(self):
        """
        Generate convergence data (MOCHA vs FedAvg vs AoI-MOCHA)
        AoI-MOCHA converges fastest due to freshness weighting
        """
        iterations = np.arange(1, 101)

        # FedAvg convergence (slowest)
        fedavg_acc = 0.95 - 0.25 * np.exp(-0.025 * iterations)

        # MOCHA convergence (faster)
        mocha_acc = 0.95 - 0.15 * np.exp(-0.04 * iterations)

        # AoI-MOCHA convergence (fastest - proposed method)
        aoi_mocha_acc = 0.95 - 0.12 * np.exp(-0.05 * iterations)

        return iterations, mocha_acc, fedavg_acc, aoi_mocha_acc

